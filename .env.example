# Vercel KV (Upstash Redis) — required for shared state across browsers on Vercel
# Get these from your Vercel project dashboard → Storage → Create KV Database
KV_URL=https://your-kv-instance.upstash.io
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token

# Optional: Override demo federation name/description
# NEXT_PUBLIC_WORKHOUSE_FEDERATION_NAME=Workhouse Festival
# NEXT_PUBLIC_WORKHOUSE_FEDERATION_DESCRIPTION=A shared festival space for playful exchange

# Optional: Override federation window (ISO timestamps)
# NEXT_PUBLIC_WORKHOUSE_FEDERATION_STARTED_AT=2026-06-19T07:00:00.000Z
# NEXT_PUBLIC_WORKHOUSE_FEDERATION_ENDS_AT=2026-06-21T16:00:00.000Z
# NEXT_PUBLIC_WORKHOUSE_FEDERATION_PUBLISHED=true

# Optional: Demo clock override (useful for testing)
# NEXT_PUBLIC_WORKHOUSE_DEMO_NOW=2026-06-20T10:00:00.000Z
